  "cli_parse": [
    {
      "data": {
        "id": "cp_start",
        "label": "Start Parse",
        "type": "start",
        "description": "Input: Raw Tokens"
      }
    },
    {
      "data": {
        "id": "cp_user",
        "label": "Check user=",
        "type": "decision",
        "description": "First token must be user=..."
      }
    },
    {
      "data": {
        "id": "cp_sanitize",
        "label": "Sanitize",
        "type": "process",
        "description": "Lowercase, letters only"
      }
    },
    {
      "data": {
        "id": "cp_len",
        "label": "Length Check",
        "type": "decision",
        "description": "Must be >= 6 chars"
      }
    },
    {
      "data": {
        "id": "cp_tokens",
        "label": "Tokenize Rest",
        "type": "process",
        "description": "Loop through remaining args"
      }
    },
    {
      "data": {
        "id": "cp_cust_qa",
        "label": "Cust vs QA",
        "type": "decision",
        "description": "Exactly one required"
      }
    },
    {
      "data": {
        "id": "cp_target",
        "label": "Form Target",
        "type": "process",
        "description": "user_code + customer_id"
      }
    },
    {
      "data": {
        "id": "cp_t_len",
        "label": "Target Length",
        "type": "decision",
        "description": "Must be <= 51 chars"
      }
    },
    {
      "data": {
        "id": "cp_return",
        "label": "Return Options",
        "type": "end",
        "description": "Valid RestoreCLIOptions"
      }
    },
    {
      "data": {
        "source": "cp_start",
        "target": "cp_user",
        "label": ""
      }
    },
    {
      "data": {
        "source": "cp_user",
        "target": "cp_sanitize",
        "label": "Found"
      }
    },
    {
      "data": {
        "source": "cp_sanitize",
        "target": "cp_len",
        "label": ""
      }
    },
    {
      "data": {
        "source": "cp_len",
        "target": "cp_tokens",
        "label": ">= 6"
      }
    },
    {
      "data": {
        "source": "cp_tokens",
        "target": "cp_cust_qa",
        "label": ""
      }
    },
    {
      "data": {
        "source": "cp_cust_qa",
        "target": "cp_target",
        "label": "Valid"
      }
    },
    {
      "data": {
        "source": "cp_target",
        "target": "cp_t_len",
        "label": ""
      }
    },
    {
      "data": {
        "source": "cp_t_len",
        "target": "cp_return",
        "label": "<= 51"
      }
    }
  ],

# =============================================================================
# pullDB Compose environment — copy to .env.blue / .env.green as needed
# =============================================================================

# Full ECR image URI with version tag (never use :latest)
# Format: <account>.dkr.ecr.<region>.amazonaws.com/pulldb:<version>
PULLDB_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/pulldb:1.3.0

# Container name — must be unique per color
# Values: pulldb-blue  or  pulldb-green
CONTAINER_NAME=pulldb-blue

# Ports exposed on the host
# Active container: 8000/8080 (real traffic)
# Validation container: 18000/18080 (internal only)
PORT_WEB=8000
PORT_API=8080

# Upgrade only: path to the dump file inside the container.
# Set by upgrade.sh — leave empty for fresh installs and restarts.
PULLDB_IMPORT_DUMP=

# =============================================================================
# Validation settings (used by validate.sh)
# =============================================================================

# S3 path to the QA template backup location.
# validate.sh picks the most recent backup under this prefix.
# Example: s3://your-backup-bucket/daily/stg/qatemplate/
PULLDB_VALIDATE_S3_PATH=s3://your-backup-bucket/daily/stg/qatemplate/

# AWS profile to use for S3 access during validation (blank = instance role)
PULLDB_VALIDATE_AWS_PROFILE=

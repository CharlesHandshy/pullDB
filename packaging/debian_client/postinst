#!/bin/bash
set -e

INSTALL_PREFIX="/opt/pulldb.client"
BIN_DIR="/usr/local/bin"
SYSTEM_USER="pulldb_service"
SYSTEM_GROUP="pulldb_service"

# Embedded Python location
EMBEDDED_PYTHON="${INSTALL_PREFIX}/python/bin/python3"

create_group_and_user() {
    if ! getent group "${SYSTEM_GROUP}" >/dev/null 2>&1; then
        addgroup --system "${SYSTEM_GROUP}"
    fi
    if ! id -u "${SYSTEM_USER}" >/dev/null 2>&1; then
        # Use /opt/pulldb.service as home if server is installed, otherwise /opt/pulldb.client
        if [ -d "/opt/pulldb.service" ]; then
            adduser --system --ingroup "${SYSTEM_GROUP}" --home "/opt/pulldb.service" --shell /usr/sbin/nologin "${SYSTEM_USER}"
        else
            adduser --system --ingroup "${SYSTEM_GROUP}" --home "${INSTALL_PREFIX}" --shell /usr/sbin/nologin "${SYSTEM_USER}"
        fi
    fi
}

# Create venv and install
if [ "$1" = "configure" ]; then
    echo "Setting up pullDB client in ${INSTALL_PREFIX}..."
    
    # Verify embedded Python exists
    if [ ! -x "${EMBEDDED_PYTHON}" ]; then
        echo "ERROR: Embedded Python not found at ${EMBEDDED_PYTHON}"
        exit 1
    fi
    
    PYTHON_VERSION=$("${EMBEDDED_PYTHON}" --version 2>&1)
    echo "Using embedded ${PYTHON_VERSION}"
    
    # Ensure user exists
    create_group_and_user
    
    # Create venv using embedded Python
    if [ ! -d "${INSTALL_PREFIX}/venv" ]; then
        echo "Creating virtual environment..."
        "${EMBEDDED_PYTHON}" -m venv "${INSTALL_PREFIX}/venv"
    fi

    # Install wheel
    WHEEL_FILE=$(ls ${INSTALL_PREFIX}/dist/*.whl 2>/dev/null | head -n 1)
    if [ -n "$WHEEL_FILE" ]; then
        echo "Installing pulldb package..."
        "${INSTALL_PREFIX}/venv/bin/pip" install --quiet --upgrade pip wheel
        "${INSTALL_PREFIX}/venv/bin/pip" install --quiet --upgrade "$WHEEL_FILE"
    else
        echo "Warning: No wheel found in ${INSTALL_PREFIX}/dist/"
    fi
    
    # Ensure ownership and permissions for system-wide CLI access
    chown -R "${SYSTEM_USER}:${SYSTEM_GROUP}" "${INSTALL_PREFIX}"
    
    # Make install directory and venv world-readable/executable
    chmod 755 "${INSTALL_PREFIX}"
    chmod 755 "${INSTALL_PREFIX}/python"
    chmod 755 "${INSTALL_PREFIX}/venv"
    chmod 755 "${INSTALL_PREFIX}/venv/bin"
    chmod 755 "${INSTALL_PREFIX}/venv/lib"
    find "${INSTALL_PREFIX}/venv/lib" -type d -exec chmod 755 {} \;
    find "${INSTALL_PREFIX}/venv/lib" -type f -exec chmod 644 {} \;
    chmod 755 "${INSTALL_PREFIX}/venv/bin/pulldb" 2>/dev/null || true

    # Symlink binary for system-wide access
    ln -sf "${INSTALL_PREFIX}/venv/bin/pulldb" "${BIN_DIR}/pulldb"
    
    echo ""
    echo "pullDB client installed successfully."
    echo "  Python:  ${PYTHON_VERSION} (embedded)"
    echo "  Binary:  ${BIN_DIR}/pulldb"
    echo "  Run 'pulldb --help' to verify."
fi

exit 0

#!/bin/bash
# =============================================================================
# pulldb-client preinst - Runs BEFORE package installation
# =============================================================================
# With embedded Python, no external Python dependency checks needed.
# =============================================================================

log_info()  { echo "[pulldb-client] $*"; }

case "$1" in
    install|upgrade)
        log_info "Installing pulldb-client with embedded Python 3.12..."
        log_info "System Python will not be modified."
        ;;
    abort-upgrade)
        ;;
    *)
        ;;
esac

exit 0

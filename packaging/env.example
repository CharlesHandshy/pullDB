# =============================================================================
# pullDB Environment Configuration
# =============================================================================
# This file defines all configurable settings for pullDB.
# Deploy to: /opt/pulldb.service/.env
#
# SETTINGS PRIORITY (highest to lowest):
#   1. Database `settings` table  (runtime override via `pulldb settings set`)
#   2. This .env file             (requires service restart)
#   3. Built-in defaults          (hardcoded fallbacks)
#
# Use `pulldb settings list` to see effective values and their sources.
# =============================================================================


# =============================================================================
# AWS CONFIGURATION
# =============================================================================

# AWS profile for Secrets Manager access (dev account 345321506926)
# Leave empty to use EC2 instance profile credentials directly
PULLDB_AWS_PROFILE=pr-dev

# AWS profile for S3 backup access (cross-account)
# This is the DEFAULT profile - can be overridden per backup location
# Use pr-staging for staging backups, pr-prod for production backups
PULLDB_S3_AWS_PROFILE=pr-staging

# AWS region
AWS_DEFAULT_REGION=us-east-1


# =============================================================================
# MYSQL COORDINATION DATABASE
# =============================================================================
# Connection settings for the pullDB coordination database.
# Credentials are resolved from AWS Secrets Manager.
#
# Three MySQL users are supported for least-privilege access:
#   - pulldb_api:    Used by API service (limited permissions)
#   - pulldb_worker: Used by worker service (job management permissions)
#   - pulldb_loader: Used by myloader on TARGET database hosts (restore permissions)
#
# See docs/mysql-schema.md for grant statements.

# Coordination database secret (REQUIRED)
# Format: aws-secretsmanager:/secret/path
# The secret should contain: {"host": "...", "password": "..."}
PULLDB_COORDINATION_SECRET=aws-secretsmanager:/pulldb/mysql/coordination-db

# MySQL connection settings
# These override values from Secrets Manager if set
# PULLDB_MYSQL_HOST=localhost
PULLDB_MYSQL_PORT=3306

# Coordination database name
PULLDB_MYSQL_DATABASE=pulldb_service

# Service-specific MySQL users (REQUIRED)
# Each service uses its own least-privilege user
# See schema/pulldb_service/03000_mysql_users.sql for grant statements
PULLDB_API_MYSQL_USER=pulldb_api
PULLDB_WORKER_MYSQL_USER=pulldb_worker

# Unix socket path (optional, overrides host/port if set)
# PULLDB_MYSQL_SOCKET=/var/run/mysqld/mysqld.sock

# NOTE: pulldb_loader credentials are stored per-host in the db_hosts table
# Each target host has a credential_ref pointing to its Secrets Manager secret


# =============================================================================
# S3 BACKUP LOCATIONS
# =============================================================================
# Configure where to discover backup archives.
# JSON array allows multiple locations with per-location profiles.

PULLDB_S3_BACKUP_LOCATIONS='[
  {
    "name": "production",
    "bucket_path": "s3://pestroutes-rds-backup-prod-vpc-us-east-1-s3/daily/prod/",
    "profile": "pr-prod",
    "description": "Production RDS daily backups"
  }
]'

# Simple mode (alternative to JSON - use one or the other):
# PULLDB_S3_BUCKET_PATH=s3://pestroutesrdsdbs/daily/stg/


# =============================================================================
# MYLOADER SETTINGS
# =============================================================================
# Configuration for the myloader restore tool.

# Path to myloader binary
PULLDB_MYLOADER_BINARY=/opt/pulldb.service/bin/myloader-0.21.1-1

# Default myloader arguments (applied to all restores)
# Format: One argument per line, will be joined automatically
#
# Common options (see `myloader --help` for full list):
#   --verbose=N                : Verbosity level (0-3)
#   --threads=N                : Number of restore threads
#   --max-threads-per-table=N  : Max threads per table
#   --max-threads-for-post-actions=N : Threads for post-restore actions
#   --rows=N                   : Rows per INSERT statement
#   --queries-per-transaction=N : Queries per transaction
#   --drop-table               : Drop tables before restore (was --overwrite-tables in <0.20)
#   --skip-triggers            : Don't restore triggers
#   --skip-post                : Don't restore views/procedures
#   --checksum=MODE            : Checksum mode (skip/warn/fail)
#   --retry-count=N            : Retry failed queries N times
#
# Default (optimized for large restores):
PULLDB_MYLOADER_DEFAULT_ARGS='
--max-threads-for-post-actions=1
--max-threads-for-index-creation=1
--max-threads-per-table=1
--rows=100000
--queries-per-transaction=5000
--optimize-keys=AFTER_IMPORT_PER_TABLE
--checksum=warn
--retry-count=20
--local-infile=TRUE
--ignore-errors=1146
--drop-table
--verbose=3
'

# Additional myloader arguments (appended to defaults)
# Use for environment-specific flags
# PULLDB_MYLOADER_EXTRA_ARGS=

# Number of parallel restore threads
# Default: 8
PULLDB_MYLOADER_THREADS=8

# Maximum execution time in seconds before timeout
# Default: 86400 (24 hours)
PULLDB_MYLOADER_TIMEOUT_SECONDS=86400


# =============================================================================
# DIRECTORY PATHS
# =============================================================================
# File system paths for pullDB operations.
# Recommended: Use dedicated mount (/mnt/data) for large storage needs.

# Installation prefix
PULLDB_INSTALL_PREFIX=/opt/pulldb.service

# Working directory for downloads and extraction
# Should have sufficient space for largest backup * 2
PULLDB_WORK_DIR=/mnt/data/work/pulldb.service

# Log directory
PULLDB_LOG_DIR=/mnt/data/logs/pulldb.service

# Temp directory for downloads (shared, with sticky bit)
PULLDB_TMP_DIR=/mnt/data/tmp

# Post-restore SQL scripts for customer databases
# Scripts run in lexicographic order after every customer restore
PULLDB_CUSTOMERS_AFTER_SQL_DIR=/opt/pulldb.service/after_sql/customer

# Post-restore SQL scripts for QA template databases
PULLDB_QA_TEMPLATE_AFTER_SQL_DIR=/opt/pulldb.service/after_sql/quality


# =============================================================================
# TARGET DATABASE DEFAULTS
# =============================================================================

# Default target database host when not specified in CLI
# Must match a hostname in the db_hosts table
# PULLDB_DEFAULT_DBHOST=dev-db-01


# =============================================================================
# API SERVER SETTINGS (pulldb-api service)
# =============================================================================

# API listen address
# Default: 0.0.0.0
# PULLDB_API_HOST=0.0.0.0

# API listen port
# Default: 8080
# PULLDB_API_PORT=8080


# =============================================================================
# WEB UI SETTINGS (pulldb-web service)
# =============================================================================
# These settings apply to the Web UI/UX interface.
# The Web UI runs as a separate service on port 8000 (pulldb-web).
# The REST API runs on port 8080 (pulldb-api) with web routes disabled.

# Enable/disable web routes in the API service
# When false, pulldb-api serves REST API only (no web dashboard)
# Default: true (web routes enabled in API)
# Set to false when running pulldb-web as a separate service
# PULLDB_WEB_ENABLED=true

# Web UI listen address
# Default: 0.0.0.0
# PULLDB_WEB_HOST=0.0.0.0

# Web UI listen port (pulldb-web service)
# Default: 8000
# PULLDB_WEB_PORT=8000

# Session secret key (REQUIRED for production)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# PULLDB_SESSION_SECRET=your-secret-key-here

# Session cookie settings
# PULLDB_SESSION_COOKIE_SECURE=true
# PULLDB_SESSION_COOKIE_HTTPONLY=true
# PULLDB_SESSION_MAX_AGE=86400


# =============================================================================
# WORKER SETTINGS (pulldb-worker service)
# =============================================================================

# Worker poll interval in seconds (how often to check for new jobs)
# Default: 5
# PULLDB_WORKER_POLL_INTERVAL=5

# Maximum concurrent jobs per worker
# Default: 1
# PULLDB_WORKER_MAX_CONCURRENT=1

# Log level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
# PULLDB_LOG_LEVEL=INFO

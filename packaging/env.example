# pullDB Environment Configuration (example)
# Copy to .env and customize for your environment
#
# This file is read by systemd services via EnvironmentFile directive.
# Changes require service restart: sudo systemctl restart pulldb-api pulldb-worker

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Installation prefix (where pulldb is installed)
PULLDB_INSTALL_PREFIX=/opt/pulldb.service

# AWS profile for S3 and Secrets Manager access
# For EC2 with Instance Profile, use the profile name configured in ~/.aws/config
PULLDB_AWS_PROFILE=pr-dev

# Coordination database credentials (Secrets Manager or SSM Parameter Store)
# Format: aws-secretsmanager:/secret/path or aws-ssm:/parameter/path
PULLDB_COORDINATION_SECRET=aws-secretsmanager:/pulldb/mysql/coordination-db

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL SETTINGS (uncomment to override defaults)
# ─────────────────────────────────────────────────────────────────────────────

# Log directory (default: ${PULLDB_INSTALL_PREFIX}/logs)
# PULLDB_LOG_DIR=/mnt/data/logs/pulldb.service

# Work directory for temporary files during restore (default: ${PULLDB_INSTALL_PREFIX}/work)
# PULLDB_WORK_DIR=/mnt/data/work/pulldb.service

# Temp directory for downloads (default: /mnt/data/tmp)
# PULLDB_TMP_DIR=/mnt/data/tmp

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# PULLDB_LOG_LEVEL=INFO

# AWS region (default: us-east-1)
# AWS_DEFAULT_REGION=us-east-1

#!/bin/sh
set -e

INSTALL_PREFIX="/opt/pulldb.service"
SYSTEM_USER="pulldb_service"
SYSTEM_GROUP="pulldb_service"
WORKER_UNIT_SOURCE="${INSTALL_PREFIX}/systemd/pulldb-worker.service"
WORKER_UNIT_DEST="/etc/systemd/system/pulldb-worker.service"
API_UNIT_SOURCE="${INSTALL_PREFIX}/systemd/pulldb-api.service"
API_UNIT_DEST="/etc/systemd/system/pulldb-api.service"
ENV_FILE="${INSTALL_PREFIX}/.env"
MERGE_SCRIPT="${INSTALL_PREFIX}/scripts/merge-config.sh"
BACKUP_TIMESTAMP=$(date +%Y%m%d-%H%M%S)

# Default data directories (can be overridden in .env)
DEFAULT_LOG_DIR="/mnt/data/logs/pulldb.service"
DEFAULT_WORK_DIR="/mnt/data/work/pulldb.service"
DEFAULT_TMP_DIR="/mnt/data/tmp"

create_group_and_user() {
    if ! getent group "${SYSTEM_GROUP}" >/dev/null 2>&1; then
        addgroup --system "${SYSTEM_GROUP}"
    fi
    if ! id -u "${SYSTEM_USER}" >/dev/null 2>&1; then
        adduser --system --ingroup "${SYSTEM_GROUP}" --home "${INSTALL_PREFIX}" --shell /usr/sbin/nologin "${SYSTEM_USER}"
    fi
}

ensure_directories() {
    # Core install directories
    install -d -o "${SYSTEM_USER}" -g "${SYSTEM_GROUP}" -m 0750 "${INSTALL_PREFIX}"
    for dir in logs work scripts systemd dist; do
        install -d -o "${SYSTEM_USER}" -g "${SYSTEM_GROUP}" -m 0750 "${INSTALL_PREFIX}/${dir}"
    done
    
    # Data directories (outside install prefix for larger storage)
    # Create parent /mnt/data if needed
    if [ ! -d "/mnt/data" ]; then
        mkdir -p /mnt/data
        chmod 755 /mnt/data
    fi
    
    # Log directory
    if [ ! -d "${DEFAULT_LOG_DIR}" ]; then
        install -d -o "${SYSTEM_USER}" -g "${SYSTEM_GROUP}" -m 0750 "${DEFAULT_LOG_DIR}"
        echo "Created log directory: ${DEFAULT_LOG_DIR}"
    fi
    
    # Work directory
    if [ ! -d "${DEFAULT_WORK_DIR}" ]; then
        install -d -o "${SYSTEM_USER}" -g "${SYSTEM_GROUP}" -m 0750 "${DEFAULT_WORK_DIR}"
        echo "Created work directory: ${DEFAULT_WORK_DIR}"
    fi
    
    # Temp directory (shared, sticky bit)
    if [ ! -d "${DEFAULT_TMP_DIR}" ]; then
        install -d -m 1777 "${DEFAULT_TMP_DIR}"
        echo "Created temp directory: ${DEFAULT_TMP_DIR}"
    fi
}

configure_aws_setup() {
    echo "Configuring AWS setup for ${SYSTEM_USER}..."
    USER_HOME=$(getent passwd "${SYSTEM_USER}" | cut -d: -f6)
    
    if [ -z "$USER_HOME" ]; then
        echo "Warning: Could not find home directory for ${SYSTEM_USER}"
        return
    fi

    AWS_DIR="${USER_HOME}/.aws"
    mkdir -p "${AWS_DIR}"
    chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${AWS_DIR}"
    chmod 700 "${AWS_DIR}"

    # Copy example to .aws directory (always update example)
    if [ -f "${INSTALL_PREFIX}/aws.config.example" ]; then
        cp "${INSTALL_PREFIX}/aws.config.example" "${AWS_DIR}/config.example"
        chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${AWS_DIR}/config.example"
    fi

    # Merge or create .aws/config
    if [ -f "${AWS_DIR}/config" ] && [ -f "${AWS_DIR}/config.example" ]; then
        # Backup existing config
        cp "${AWS_DIR}/config" "${AWS_DIR}/config.backup.${BACKUP_TIMESTAMP}"
        echo "Backed up ${AWS_DIR}/config to config.backup.${BACKUP_TIMESTAMP}"
        
        # Merge existing with new template
        if [ -x "${MERGE_SCRIPT}" ]; then
            "${MERGE_SCRIPT}" ini "${AWS_DIR}/config" "${AWS_DIR}/config.example" "${AWS_DIR}/config.merged"
            mv "${AWS_DIR}/config.merged" "${AWS_DIR}/config"
            chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${AWS_DIR}/config"
            chmod 600 "${AWS_DIR}/config"
        else
            echo "Warning: Merge script not found, preserving existing config"
        fi
    elif [ -f "${AWS_DIR}/config.example" ]; then
        cp "${AWS_DIR}/config.example" "${AWS_DIR}/config"
        chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${AWS_DIR}/config"
        chmod 600 "${AWS_DIR}/config"
        echo "Created ${AWS_DIR}/config from example."
    fi

    # Copy AWS-SETUP.md (documentation, safe to update)
    if [ -f "${INSTALL_PREFIX}/AWS-SETUP.md" ]; then
        if [ "${INSTALL_PREFIX}/AWS-SETUP.md" != "${USER_HOME}/AWS-SETUP.md" ]; then
            cp "${INSTALL_PREFIX}/AWS-SETUP.md" "${USER_HOME}/AWS-SETUP.md"
            chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${USER_HOME}/AWS-SETUP.md"
            echo "AWS setup docs copied to ${USER_HOME}/AWS-SETUP.md"
        fi
    fi
}

configure_env_file() {
    local ENV_EXAMPLE="${INSTALL_PREFIX}/env.example"
    
    if [ -f "${ENV_FILE}" ] && [ -f "${ENV_EXAMPLE}" ]; then
        # Backup existing .env
        cp "${ENV_FILE}" "${ENV_FILE}.backup.${BACKUP_TIMESTAMP}"
        echo "Backed up ${ENV_FILE} to .env.backup.${BACKUP_TIMESTAMP}"
        
        # Merge existing with new template
        if [ -x "${MERGE_SCRIPT}" ]; then
            "${MERGE_SCRIPT}" env "${ENV_FILE}" "${ENV_EXAMPLE}" "${ENV_FILE}.merged"
            mv "${ENV_FILE}.merged" "${ENV_FILE}"
            chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${ENV_FILE}"
            chmod 600 "${ENV_FILE}"
        else
            echo "Warning: Merge script not found, preserving existing .env"
        fi
    elif [ -f "${ENV_EXAMPLE}" ]; then
        # Fresh install - copy template
        cp "${ENV_EXAMPLE}" "${ENV_FILE}"
        chown "${SYSTEM_USER}:${SYSTEM_GROUP}" "${ENV_FILE}"
        chmod 600 "${ENV_FILE}"
        echo "Created ${ENV_FILE} from example."
    fi
}

validate_install() {
    echo "Validating installation..."
    if [ -x "${INSTALL_PREFIX}/venv/bin/python" ]; then
        if su -s /bin/bash "${SYSTEM_USER}" -c "${INSTALL_PREFIX}/venv/bin/python -c \"import pulldb; print('pullDB module loaded successfully')\""; then
             echo "Validation successful."
        else
             echo "Warning: pullDB module import failed. Check logs and configuration."
        fi
    fi
}

install_systemd_unit() {
    if ! command -v systemctl >/dev/null 2>&1; then
        return
    fi
    
    # Remove old copies if they exist (migrate to symlinks)
    [ -f "${WORKER_UNIT_DEST}" ] && [ ! -L "${WORKER_UNIT_DEST}" ] && rm -f "${WORKER_UNIT_DEST}"
    [ -f "${API_UNIT_DEST}" ] && [ ! -L "${API_UNIT_DEST}" ] && rm -f "${API_UNIT_DEST}"
    
    # Create symlinks to unit files in install directory
    if [ -f "${WORKER_UNIT_SOURCE}" ]; then
        ln -sf "${WORKER_UNIT_SOURCE}" "${WORKER_UNIT_DEST}"
        echo "Linked ${WORKER_UNIT_DEST} -> ${WORKER_UNIT_SOURCE}"
        systemctl enable pulldb-worker.service || true
    fi
    
    if [ -f "${API_UNIT_SOURCE}" ]; then
        ln -sf "${API_UNIT_SOURCE}" "${API_UNIT_DEST}"
        echo "Linked ${API_UNIT_DEST} -> ${API_UNIT_SOURCE}"
        systemctl enable pulldb-api.service || true
    fi
    
    systemctl daemon-reload || true
}

case "$1" in
    configure)
        create_group_and_user
        ensure_directories
        
        # Setup Python venv and install package
        echo "Setting up Python virtual environment..."
        cd "${INSTALL_PREFIX}"
        
        VENV_DIR="${INSTALL_PREFIX}/venv"
        if [ -d "${VENV_DIR}" ]; then
            echo "Existing venv found, upgrading package..."
        else
            echo "Creating new virtual environment..."
            python3 -m venv "${VENV_DIR}"
        fi
        
        # Install/upgrade the wheel
        if ls "${INSTALL_PREFIX}/dist"/pulldb-*.whl 1>/dev/null 2>&1; then
            "${VENV_DIR}/bin/pip" install --upgrade pip wheel >/dev/null
            "${VENV_DIR}/bin/pip" install --upgrade --force-reinstall "${INSTALL_PREFIX}/dist"/pulldb-*.whl
            echo "pulldb package installed successfully."
        else
            echo "Warning: No wheel found in ${INSTALL_PREFIX}/dist/"
        fi

        # Ensure ownership is correct
        chown -R "${SYSTEM_USER}:${SYSTEM_GROUP}" "${INSTALL_PREFIX}" || true
        
        # Configure environment and AWS (preserves existing files)
        configure_env_file
        configure_aws_setup
        
        # Install systemd units (symlinks)
        install_systemd_unit
        
        validate_install
        
        echo ""
        echo "Installation complete. Next steps:"
        echo "  1. Review/edit ${ENV_FILE}"
        echo "  2. Start services: sudo systemctl start pulldb-api pulldb-worker"
        echo "  3. Check status: sudo systemctl status pulldb-api pulldb-worker"
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        ;;
esac

exit 0

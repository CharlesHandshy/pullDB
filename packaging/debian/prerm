#!/bin/sh
set -e

SERVICE="pulldb-worker.service"

stop_service() {
    if command -v systemctl >/dev/null 2>&1; then
        systemctl stop "${SERVICE}" >/dev/null 2>&1 || true
        systemctl disable "${SERVICE}" >/dev/null 2>&1 || true
    fi
}

case "$1" in
    remove|upgrade|deconfigure)
        stop_service
        ;;
    failed-upgrade)
        ;;
    *)
        ;;
esac

exit 0

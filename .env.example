# pullDB Environment Configuration
# Copy this file to .env and fill in your values
# The .env file is gitignored and will not be committed

# ============================================
# MySQL Coordination Database
# ============================================
# Option 1: Direct values (local development only)
PULLDB_MYSQL_HOST=localhost
PULLDB_MYSQL_USER=root
PULLDB_MYSQL_PASSWORD=
PULLDB_MYSQL_DATABASE=pulldb

# Option 2: AWS Parameter Store reference (recommended for production)
# Set these to AWS SSM parameter paths instead of direct values
# The application will fetch the actual values from Parameter Store
# Example:
# PULLDB_MYSQL_HOST=/pulldb/prod/mysql/host
# PULLDB_MYSQL_USER=/pulldb/prod/mysql/user
# PULLDB_MYSQL_PASSWORD=/pulldb/prod/mysql/password
# PULLDB_MYSQL_DATABASE=/pulldb/prod/mysql/database

# ============================================
# AWS Configuration
# ============================================
# AWS Profile name (configured via `aws configure --profile <name>`)
# REQUIRED: pullDB only supports named AWS profiles for security
PULLDB_AWS_PROFILE=pr-prod

# S3 Bucket path (set in settings table, but can override here for testing)
# PULLDB_S3_BUCKET_PATH=pestroutes-rds-backup-prod-vpc-us-east-1-s3/daily/prod

# ============================================
# Restore Configuration
# ============================================
# Default database host (override from settings table)
PULLDB_DEFAULT_DBHOST=db-mysql-db4-dev

# Working directory for downloads and extraction
PULLDB_WORK_DIR=/mnt/data/pulldb/work

# Post-restore SQL script directories
PULLDB_CUSTOMERS_AFTER_SQL_DIR=./customers_after_sql
PULLDB_QA_TEMPLATE_AFTER_SQL_DIR=./qa_template_after_sql

# ============================================
# Logging & Monitoring
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
PULLDB_LOG_LEVEL=INFO

# Log file path (optional; defaults to stdout if not set)
# PULLDB_LOG_FILE=/var/log/pulldb/pulldb.log

# ============================================
# Development / Testing
# ============================================
# Set to 'true' to enable additional debug output
# PULLDB_DEBUG=false

{
  "cli_architecture": {
    "principle": "CLIs are thin interface clients to server applications",
    "pulldb_cli": {
      "scope": "user-facing, own work only",
      "commands": ["restore", "status", "cancel", "history", "search"],
      "excluded": ["prune-logs", "cleanup-staging", "orphan-report", "delete-orphans"]
    },
    "pulldb_admin_cli": {
      "scope": "admin-facing, system-wide operations",
      "commands": ["prune-logs", "cleanup-staging", "orphan-report", "delete-orphans"]
    },
    "flow": "CLI → API Service → Worker Service"
  },
  "accounts": {
    "development": "345321506926",
    "staging": "333204494849",
    "production": "448509429610"
  },
  "s3": {
    "staging_bucket": "pestroutesrdsdbs",
    "staging_prefix": "daily/stg/",
    "production_bucket": "pestroutes-rds-backup-prod-vpc-us-east-1-s3",
    "production_prefix": "daily/prod/"
  },
  "iam": {
    "dev_ec2_role": "arn:aws:iam::345321506926:role/pulldb-ec2-service-role",
    "staging_cross_account_role": "arn:aws:iam::333204494849:role/pulldb-cross-account-readonly",
    "production_cross_account_role": "arn:aws:iam::448509429610:role/pulldb-cross-account-readonly",
    "instance_profile": "pulldb-instance-profile"
  },
  "secrets": {
    "api": "/pulldb/mysql/api",
    "worker": "/pulldb/mysql/worker",
    "loader": "/pulldb/mysql/loader"
  },
  "schema": {
    "canonical_doc": "docs/mysql-schema.md",
    "database": "pulldb_service",
    "schema_dir": "schema/pulldb_service/",
    "hosts_table": "db_hosts"
  },
  "mysql_users": {
    "api": "pulldb_api",
    "worker": "pulldb_worker",
    "loader": "pulldb_loader"
  },
  "env_vars": {
    "api_user": "PULLDB_API_MYSQL_USER",
    "worker_user": "PULLDB_WORKER_MYSQL_USER",
    "database": "PULLDB_MYSQL_DATABASE"
  },
  "paths": {
    "install_root": "/opt/pulldb.service",
    "venv": "/opt/pulldb.service/venv",
    "logs": "/opt/pulldb.service/logs",
    "work_directory": "/opt/pulldb.service/work",
    "systemd_api": "/etc/systemd/system/pulldb-api.service",
    "systemd_worker": "/etc/systemd/system/pulldb-worker.service"
  },
  "binaries": {
    "myloader_path": "/opt/pulldb.service/bin/",
    "myloader_source": "pulldb/binaries/"
  },
  "lessons_learned": [
    {
      "topic": "AWS Profile Scoping",
      "issue": "PULLDB_AWS_PROFILE=pr-prod breaks Secrets Manager access",
      "fix": "Use PULLDB_S3_AWS_PROFILE=pr-prod for S3, leave PULLDB_AWS_PROFILE unset or pr-dev"
    },
    {
      "topic": "MySQL User Separation",
      "issue": "Single shared MySQL user violated least-privilege principle",
      "fix": "Use pulldb_api, pulldb_worker, pulldb_loader with minimal grants per role"
    },
    {
      "topic": "CLI Scope Separation",
      "issue": "Admin commands in user CLI could affect other users' work",
      "fix": "User CLI (pulldb) for own work only; admin CLI (pulldb-admin) for system operations"
    },
    {
      "topic": "AWS Region Configuration",
      "issue": "boto3 failed with 'You must specify a region' outside AWS",
      "fix": "Set AWS_DEFAULT_REGION in .env; CredentialResolver uses fallback chain",
      "phase": "2"
    },
    {
      "topic": "Settings Sync",
      "issue": "Settings changes required editing both db AND .env manually",
      "fix": "Use pulldb-admin settings pull/push/diff commands",
      "phase": "2"
    },
    {
      "topic": "dpkg Upgrade Migrations",
      "issue": "dpkg -i does NOT auto-run schema migrations",
      "fix": "After dpkg install, run: sudo /opt/pulldb.service/scripts/pulldb-migrate.sh migrate",
      "phase": "2"
    },
    {
      "topic": "CLI dotenv Auto-Loading",
      "issue": "CLIs required manual 'source .env' before use",
      "fix": "load_dotenv() added at module import in admin.py and main.py",
      "phase": "2"
    }
  ],
  "migrations": {
    "script": "/opt/pulldb.service/scripts/pulldb-migrate.sh",
    "commands": ["status", "migrate", "verify", "baseline", "rollback"],
    "post_install_required": true
  },
  "settings_sync": {
    "pull": "db → .env (download settings from database)",
    "push": ".env → db (upload settings to database)",
    "diff": "compare db vs .env for differences"
  },
  "web_ui": {
    "sidebar_pattern": {
      "name": "hover-reveal",
      "default_state": "hidden (translateX(-100%))",
      "content_width": "100% (margin-left: 0)",
      "trigger_zone_width": "12px",
      "open_delay_ms": 150,
      "close_delay_ms": 200,
      "css_classes": {
        "sidebar_open": ".sidebar.open",
        "backdrop": ".sidebar-backdrop.visible",
        "trigger": ".sidebar-trigger"
      }
    },
    "device_detection": {
      "method": "CSS media queries",
      "mouse_trackpad": {
        "query": "@media (hover: hover) and (pointer: fine)",
        "behavior": "hide menu button, use edge hover trigger"
      },
      "touch_devices": {
        "query": "@media (hover: none), (pointer: coarse)",
        "behavior": "show menu button, hide edge trigger"
      },
      "media_values": {
        "hover_hover": "device supports true hover",
        "hover_none": "no hover support (touch)",
        "pointer_fine": "precise pointer (mouse)",
        "pointer_coarse": "imprecise pointer (finger)"
      },
      "js_alternative": {
        "hasHover": "window.matchMedia('(hover: hover)').matches",
        "hasFinePointer": "window.matchMedia('(pointer: fine)').matches",
        "isTouchDevice": "navigator.maxTouchPoints > 0"
      }
    },
    "responsive_table": {
      "key_class": ".main-content.full-height-page",
      "layout": {
        "container": "height: 100vh; max-height: 100vh; overflow: hidden",
        "children": "flex: 1; min-height: 0 (allow shrinking)"
      }
    },
    "virtual_scroller": {
      "pattern": "3-window",
      "windows": ["before viewport", "visible viewport", "after viewport"],
      "each_window_size": "viewport height worth of rows",
      "overscan_default": 10,
      "requires": "fixed row height"
    },
    "hca_structure": {
      "shared": "web/shared/",
      "entities": "web/entities/",
      "features": "web/features/",
      "widgets": "web/widgets/",
      "pages": "web/pages/"
    }
  },
  "auth": {
    "modes": {
      "trusted": "X-Pulldb-User header trusted directly (dev)",
      "session": "bcrypt password + session token cookie (prod)",
      "both": "tries trusted header first, falls back to session"
    },
    "config_var": "PULLDB_AUTH_MODE",
    "default_mode": "both",
    "password_algorithm": "bcrypt",
    "work_factor": 12,
    "session_ttl_hours": 24,
    "session_cookie": "pulldb_session",
    "files": {
      "password": "pulldb/auth/password.py",
      "repository": "pulldb/auth/repository.py",
      "middleware": "pulldb/api/auth.py",
      "web_routes": "pulldb/web/features/auth/"
    }
  },
  "rbac": {
    "roles": ["USER", "MANAGER", "ADMIN"],
    "permissions": {
      "view_own_jobs": ["USER", "MANAGER", "ADMIN"],
      "submit_own_jobs": ["USER", "MANAGER", "ADMIN"],
      "cancel_own_jobs": ["USER", "MANAGER", "ADMIN"],
      "view_managed_jobs": ["MANAGER", "ADMIN"],
      "cancel_managed_jobs": ["MANAGER", "ADMIN"],
      "view_all_jobs": ["ADMIN"],
      "cancel_any_job": ["ADMIN"],
      "manage_users": ["ADMIN"],
      "orphan_cleanup": ["ADMIN"],
      "system_settings": ["ADMIN"]
    },
    "files": {
      "permissions": "pulldb/domain/permissions.py",
      "models": "pulldb/domain/models.py"
    },
    "manager_relationship_table": "manager_user_relationship"
  },
  "simulation": {
    "package": "pulldb/simulation/",
    "components": {
      "api": "simulation/api/router.py",
      "engine": "simulation/core/engine.py",
      "bus": "simulation/core/bus.py",
      "state": "simulation/core/state.py",
      "runner": "simulation/core/queue_runner.py",
      "seeding": "simulation/core/seeding.py",
      "scenarios": "simulation/core/scenarios.py"
    },
    "adapters": {
      "mock_mysql": "simulation/adapters/mock_mysql.py",
      "mock_s3": "simulation/adapters/mock_s3.py",
      "mock_exec": "simulation/adapters/mock_exec.py"
    },
    "exports": ["MockJobRepository", "MockUserRepository", "MockS3Client", "SimulationEngine"]
  },
  "phase4_schema": {
    "migrations": [
      {"file": "070_auth_users_role.sql", "purpose": "adds role column to auth_users"},
      {"file": "071_auth_credentials.sql", "table": "auth_credentials"},
      {"file": "072_sessions.sql", "table": "sessions"},
      {"file": "072_password_reset.sql", "table": "password_reset_tokens"},
      {"file": "073_manager_user_relationship.sql", "table": "manager_user_relationship"},
      {"file": "074_audit_logs.sql", "table": "audit_logs"}
    ],
    "tables": ["auth_credentials", "sessions", "password_reset_tokens", "manager_user_relationship", "audit_logs"]
  }
}

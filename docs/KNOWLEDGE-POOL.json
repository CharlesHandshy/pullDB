  "lessons_learned": [
    {
      "topic": "AWS Profile Scoping",
      "issue": "PULLDB_AWS_PROFILE=pr-prod breaks Secrets Manager access",
      "fix": "Use PULLDB_S3_AWS_PROFILE=pr-prod for S3, leave PULLDB_AWS_PROFILE unset or pr-dev"
    },
    {
      "topic": "MySQL User Separation",
      "issue": "Single shared MySQL user violated least-privilege principle",
      "fix": "Use pulldb_api, pulldb_worker, pulldb_loader with minimal grants per role"
    },
    {
      "topic": "CLI Scope Separation",
      "issue": "Admin commands in user CLI could affect other users' work",
      "fix": "User CLI (pulldb) for own work only; admin CLI (pulldb-admin) for system operations"
    },
    {
      "topic": "AWS Region Configuration",
      "issue": "boto3 failed with 'You must specify a region' outside AWS",
      "fix": "Set AWS_DEFAULT_REGION in .env; CredentialResolver uses fallback chain",
      "phase": "2"
    },
    {
      "topic": "Settings Sync",
      "issue": "Settings changes required editing both db AND .env manually",
      "fix": "Use pulldb-admin settings pull/push/diff commands",
      "phase": "2"
    },
    {
      "topic": "dpkg Upgrade Schema",
      "issue": "Schema files auto-applied during dpkg install",
      "fix": "Postinst applies new files from schema/pulldb_service/ and tracks in schema_migrations table",
      "phase": "2"
    },
    {
      "topic": "CLI dotenv Auto-Loading",
      "issue": "CLIs required manual 'source .env' before use",
      "fix": "load_dotenv() added at module import in admin.py and main.py",
      "phase": "2"
    }
  ],
  "schema_management": {
    "location": "/opt/pulldb.service/schema/pulldb_service/",
    "tracking_table": "schema_migrations",
    "auto_applied": true,
    "verify_command": "mysql -e \"SELECT * FROM pulldb_service.schema_migrations ORDER BY applied_at\""
  },
  "settings_sync": {
    "pull": "db \u2192 .env (download settings from database)",
    "push": ".env \u2192 db (upload settings to database)",
    "diff": "compare db vs .env for differences"
  },

    "CRITICAL": "Resume file contains files TO PROCESS, NOT files to skip",
    "common_mistake": "Putting completed files in resume (opposite of intended behavior)",
    "correct_usage": {
      "resume_file_content": "Only the .sql.gz files you want myloader to load",
      "includes": [
        "schema files (-schema.sql.gz)",
        "data files (.00000.sql.gz, etc.)"
      ],
      "excludes": [
        "already loaded tables",
        "metadata files"
      ]
    },
    "commands": {
      "create_resume": "ls -1 *.sql.gz | grep -E '^dbname\\.tablename[\\.-]' > resume",
      "verify": "wc -l resume && grep -c tablename resume"
    },
